library(readr)
year_2025_pitches <- read_csv("Week 10/data/year-2025-pitches.csv")
View(year_2025_pitches)
year_2025_pitches |>
compmus_wrangle_chroma() |>
filter(row_number() %% 50L == 0L) |>
compmus_match_pitch_template(
key_templates,         # Change to chord_templates if desired
method = "euclidean",  # Try different distance metrics
norm = "manhattan"     # Try different norms
) |>
ggplot(
aes(x = start + duration / 2, width = 50 * duration, y = name, fill = d)
) +
geom_tile() +
scale_fill_viridis_c(guide = "none") +
theme_minimal() +
labs(x = "Time (s)", y = "")
